# ─── Required ────────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens
JWT_SECRET=

# MongoDB Atlas connection string
# Leave empty to use the in-memory database during development
MONGO_URI=""

# Environment
NODE_ENV=development

# Port
PORT=3000

# ─── Optional ────────────────────────────────────────────────────────────────

# Public URL of the application (optional)
APP_URL=http://localhost:3000